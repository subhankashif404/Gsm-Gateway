# ============================================================
#  GSM Gateway - Vercel Production Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Server (Vercel will override PORT)
PORT=3000
NODE_ENV=production

# Modem Configuration
# Note: Modems require physical hardware - not available on Vercel serverless
# Use this for local development only
MODEM_PORTS=
MODEM_AUTO_DETECT=true
MODEM_BAUD_RATE=115200

# SIM Rotation Settings
MAX_SMS_PER_SIM_PER_DAY=625
SMS_SEND_DELAY_MS=2000

# SIM Health & Auto-Blocking
MAX_CONSECUTIVE_FAILURES=5
SIM_ALERT_THRESHOLDS=80,90,100
AUTO_BLOCK_ENABLED=true

# Dashboard Auth (CHANGE THIS!)
DASHBOARD_PASSWORD=change_this_to_secure_password

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (Vercel will use ephemeral storage)
# For production, consider using a cloud database service
DB_PATH=./data/gateway.db

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
